{
  "manifest_version": 3,
  "name": "SNS Detox Redirect",
  "version": "1.0.0",
  "description": "Redirect away from time-sink sites after a configurable dwell time and probability. / 対象ドメインの滞在時間と確率でリダイレクトします。",
  "author": "Satoru Sakurai",
  "homepage_url": "https://github.com/sakurairai/detox",
  "minimum_chrome_version": "102",
  "permissions": ["webNavigation", "tabs", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_popup": "options.html",
    "default_title": "SNS Detox Redirect",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
